        <script type="text/javascript">
            window.addEventListener('DOMContentLoaded',function () {
                $('#file-form').submit(function (e) {
                    e.preventDefault();
                });

                $("#upld-sel-btn").click(function () {
                    $("#upld-file").click()
                })

                $(".f-rec > .f-mod").each(function (i, elem) {
                    let timestamp = $(elem).text() 
                    let date = new Date(timestamp * 1000);
                    $(elem).text(date.toISOString().split('.')[0].replace('T', ' '))
                    $(elem).attr("val", timestamp)
                })

                $(".f-rec > .f-size").each(function (i, elem) {
                    let size = +$(elem).text();
                    $(elem).text(humanFileSize(size))
                    $(elem).attr("val", size)
                })

                $(".file-list th").each(function (i, elem) {
                    set_table_col_sortable(elem)
                })

                $("#upld-file").on('input', function() {
                    let name = "no file selected"
                    let size = 0
                    let file = this.files[0]

                    if (file) {
                        name = file.name
                        size = file.size
                    }

                    window.file_to_upload = file
                    let text = ""

                    if (name)
                        text += name
                    if (size)
                        text += "\n\nsize: " + humanFileSize(size)

                    if (size > 100000000 /* 100 MB */) {
                        text += "\nfile size is too large to upload!"
                    }

                    $("#upld-file + .readonly").text(text)
                });

                $("#upld-btn").click(function () {
                    console.log(window.file_to_upload)
                    var form_data = new FormData($("#file-form").get(0));
                    console.log(form_data)

                    $.ajax({
                        url: '/upload-file.php',
                        type: 'POST',
                        data: form_data,
                        async: false,
                        success: function (data) {
                            create_popup(
                                false, "File uploaded", data,
                                function () {
                                    window.location.reload();
                            });
                        },
                        cache: false,
                        contentType: false,
                        processData: false
                    }).fail(function (err) {
                        create_popup(
                            true, "Failed to upload file", "Error: " + err.responseText,
                            function () {
                                $(".popup-holder").remove()
                        });
                    })
                })
            })
        </script>
